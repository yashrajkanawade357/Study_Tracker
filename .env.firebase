# Build-time env for the Firebase Hosting build ONLY (loaded via `vite build --mode firebase`).
# Vite always loads .env first, so this just ADDS the AI proxy override on top of
# the existing VITE_SUPABASE_* vars. Local dev and the Vercel build never load this file.
#
# Points the app at the Supabase Edge Function instead of the (non-existent on
# Firebase) /api/openai route. Deploy the function first:
#   supabase functions deploy openai-proxy --no-verify-jwt
VITE_AI_PROXY_URL=https://qdznikbezauhjindumul.supabase.co/functions/v1/openai-proxy
